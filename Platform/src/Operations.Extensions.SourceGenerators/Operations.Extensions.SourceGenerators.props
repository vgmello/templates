<Project>
  <PropertyGroup>
    <!--
      Defines the default value for whether to use snake_case for DB parameters
      when DbCommandAttribute.ParamsCase is DbParamsCase.Default.
      Consumed by Operations.Extensions.SourceGenerators.
    -->
    <UseSnakeCaseForDbCommands Condition="'$(UseSnakeCaseForDbCommands)' == ''">false</UseSnakeCaseForDbCommands>
  </PropertyGroup>
  <ItemGroup>
    <!--
      Makes the UseSnakeCaseForDbCommands property visible to the C# compiler
      and subsequently to source generators.
    -->
    <CompilerVisibleProperty Include="UseSnakeCaseForDbCommands" />
  </ItemGroup>
</Project>
