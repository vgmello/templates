<Project Sdk="Microsoft.NET.Sdk.Web">

    <PropertyGroup>
        <IsTestProject>true</IsTestProject>
        <NoWarn>$(NoWarn);CS0436;</NoWarn>
    </PropertyGroup>

    <ItemGroup>
        <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing"/>
        <PackageReference Include="NSubstitute"/>
        <PackageReference Include="NetArchTest.Rules"/>
        <PackageReference Include="Testcontainers"/>
        <PackageReference Include="Testcontainers.PostgreSql"/>
        <PackageReference Include="Grpc.Tools"/>
    </ItemGroup>

    <ItemGroup>
        <ProjectReference Include="..\..\src\Housekeeping.Api\Housekeeping.Api.csproj"/>
        <ProjectReference Include="..\..\src\Housekeeping.BackOffice\Housekeeping.BackOffice.csproj"/>
        <ProjectReference Include="..\..\src\Housekeeping.Contracts\Housekeeping.Contracts.csproj"/>
        <ProjectReference Include="..\..\src\Housekeeping\Housekeeping.csproj"/>
    </ItemGroup>

    <ItemGroup>
        <Protobuf Include="..\..\src\Housekeeping.Api\**\Protos\**\*.proto"
                  ProtoRoot="..\..\src\Housekeeping.Api\"
                  GrpcServices="Client"
                  Link="Integration\%(RecursiveDir)%(Filename)%(Extension)"/>
    </ItemGroup>

    <ItemGroup>
        <None Update="xunit.runner.json">
            <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
        </None>
    </ItemGroup>

</Project>